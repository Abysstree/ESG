# Backend
ESG_ENV=local
ESG_API_HOST=127.0.0.1
ESG_API_PORT=8000

# LLM provider settings are fallback defaults. The app can also save provider
# configs locally in SQLite from the frontend settings panel.
ESG_LLM_PROVIDER=mock
ESG_LLM_API_KEY=
ESG_LLM_BASE_URL=https://api.openai.com/v1
ESG_LLM_MODEL=gpt-4.1-mini
# ESG_API_KEY_ENCRYPTION_KEY is optional. If unset, ESG creates a local key in
# data/secrets/api-key-fernet.key and uses it to encrypt provider API keys.
# ESG_LLM_PROVIDER can be mock, deepseek, openai_compatible, anthropic, or google.
# DeepSeek default: ESG_LLM_BASE_URL=https://api.deepseek.com
# DeepSeek default model: ESG_LLM_MODEL=deepseek-v4-flash
# Anthropic default: ESG_LLM_BASE_URL=https://api.anthropic.com
# Anthropic default model: ESG_LLM_MODEL=claude-sonnet-4-6
# Google default: ESG_LLM_BASE_URL=https://generativelanguage.googleapis.com
# Google default model: ESG_LLM_MODEL=gemini-3.5-flash

# Search provider settings are normally configured from the frontend API settings
# panel and saved encrypted in SQLite. Supported MVP providers: Exa, Tavily.
# Exa default: https://api.exa.ai
# Tavily default: https://api.tavily.com

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
